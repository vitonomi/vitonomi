# vitonomi environment variables

# Autonomi testnet (for local development)
AUTONOMI_PEER_ADDR=

# Venice.ai API key (for self-hosted mode classification)
VENICE_API_KEY=

# Web app mode: "hosted" or "selfhosted"
VITONOMI_MODE=selfhosted

# Hosted mode API endpoint (leave empty for self-hosted)
VITONOMI_API_URL=

# Debug logging (set to "true" to enable)
DEBUG=
