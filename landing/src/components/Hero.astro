---
interface CtaProps {
  readonly label: string;
  readonly href: string;
}

interface Props {
  readonly eyebrow?: string;
  readonly title: string;
  /** Optional HTML override for the h1. Used for in-title emphasis. */
  readonly titleHtml?: string;
  readonly subtitle: string;
  readonly primaryCta?: CtaProps;
  readonly secondaryCta?: CtaProps;
  /** Optional small pill displayed next to the eyebrow. */
  readonly badge?: string;
}

const { eyebrow, title, titleHtml, subtitle, primaryCta, secondaryCta, badge } = Astro.props;
---

<section class="hero plain">
  <div class="container">
    {
      (eyebrow || badge) && (
        <div class="hero__meta">
          {eyebrow && <p class="eyebrow">{eyebrow}</p>}
          {badge && <span class="hero__badge">{badge}</span>}
        </div>
      )
    }
    <h1 class="hero__title" set:html={titleHtml ?? title} />
    <p class="hero__subtitle lede">{subtitle}</p>
    {
      (primaryCta || secondaryCta) && (
        <div class="hero__actions actions">
          {primaryCta && (
            <a class="cta" href={primaryCta.href}>
              {primaryCta.label}
            </a>
          )}
          {secondaryCta && (
            <a class="cta cta--ghost" href={secondaryCta.href}>
              {secondaryCta.label}
            </a>
          )}
        </div>
      )
    }
  </div>
</section>

<style>
  .hero {
    padding: clamp(4rem, 10vw, 8rem) 0 clamp(3rem, 6vw, 5rem);
    background:
      radial-gradient(ellipse 60% 50% at 85% 20%, var(--glow-orange), transparent),
      radial-gradient(ellipse 40% 60% at 10% 80%, var(--glow-amber), transparent), var(--bg);
  }

  .hero__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .hero__meta .eyebrow {
    margin: 0;
  }

  .hero__badge {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
    line-height: 1;
  }

  .hero__title {
    max-width: 22ch;
    margin: 0 0 1.25rem;
    animation: hero-in 0.6s ease-out both;
  }
  .hero__subtitle {
    max-width: 58rem;
    margin-bottom: 0;
    animation: hero-in 0.6s ease-out 0.15s both;
  }
  .hero__actions {
    animation: hero-in 0.6s ease-out 0.3s both;
  }

  @keyframes hero-in {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__title,
    .hero__subtitle,
    .hero__actions {
      animation: none;
    }
  }
</style>
