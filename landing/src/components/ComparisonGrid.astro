---
interface Side {
  readonly title: string;
  readonly items: readonly string[];
}

interface Props {
  readonly before: Side;
  readonly after: Side;
}

const { before, after } = Astro.props;
---

<div class="comparison" data-reveal>
  <div class="comparison__side comparison__side--before">
    <h3 class="comparison__heading">{before.title}</h3>
    <ul class="comparison__list">
      {before.items.map((item) => <li>{item}</li>)}
    </ul>
  </div>
  <div class="comparison__divider" aria-hidden="true">
    <span class="comparison__arrow">&rarr;</span>
  </div>
  <div class="comparison__side comparison__side--after">
    <h3 class="comparison__heading">{after.title}</h3>
    <ul class="comparison__list">
      {after.items.map((item) => <li>{item}</li>)}
    </ul>
  </div>
</div>

<style>
  .comparison {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    align-items: stretch;
  }

  .comparison__side {
    padding: 1.75rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .comparison__side--before {
    background: var(--bg-alt);
  }
  .comparison__side--after {
    background: linear-gradient(135deg, var(--bg) 0%, rgba(247, 147, 26, 0.04) 100%);
    border-color: var(--brand);
    box-shadow: 0 0 0 1px var(--brand-subtle);
  }

  .comparison__divider {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1rem;
  }
  .comparison__arrow {
    font-size: 1.5rem;
    color: var(--text-muted);
    font-weight: 300;
  }

  .comparison__heading {
    margin: 0 0 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .comparison__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }
  .comparison__list li {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--text);
  }
  .comparison__side--before .comparison__list li {
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    .comparison {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    .comparison__divider {
      padding: 0.25rem 0;
    }
    .comparison__arrow {
      transform: rotate(90deg);
    }
  }
</style>
