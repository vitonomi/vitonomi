---
interface Feature {
  readonly title: string;
  readonly body: string;
}

interface Props {
  readonly features: readonly Feature[];
  readonly columns?: 2 | 3 | 4;
}

const { features, columns = 3 } = Astro.props;
---

<ul class="feature-grid" data-cols={columns}>
  {
    features.map((f) => (
      <li class="feature">
        <h3 class="feature__title">{f.title}</h3>
        <p class="feature__body">{f.body}</p>
      </li>
    ))
  }
</ul>

<style>
  .feature-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: clamp(2rem, 3vw, 3rem) clamp(1.5rem, 3vw, 2.5rem);
  }
  .feature-grid[data-cols='2'] {
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
  }
  .feature-grid[data-cols='3'] {
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
  }
  .feature-grid[data-cols='4'] {
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
  }

  .feature {
    padding-top: 1.25rem;
    border-top: 1px solid var(--text);
  }

  .feature__title {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .feature__body {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.55;
  }
</style>
