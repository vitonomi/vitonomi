---
interface Props {
  readonly text: string;
  readonly caption?: string;
  /** Substring of `text` to wrap in brand-color accent. */
  readonly highlight?: string;
}

const { text, caption, highlight } = Astro.props;

function renderText(raw: string, hl?: string): string {
  if (!hl) return raw;
  const idx = raw.indexOf(hl);
  if (idx === -1) return raw;
  const before = raw.slice(0, idx);
  const after = raw.slice(idx + hl.length);
  return `${before}<span class="accent">${hl}</span>${after}`;
}
---

<div class="statement" data-reveal>
  <p class="statement__text" set:html={renderText(text, highlight)} />
  {caption && <p class="statement__caption">{caption}</p>}
</div>

<style>
  .statement {
    max-width: 48rem;
  }
  .statement__text {
    font-size: clamp(1.5rem, 2.2vw + 0.5rem, 2.25rem);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .statement__caption {
    margin: 1.25rem 0 0;
    font-size: 1rem;
    color: var(--text-muted);
  }
</style>
