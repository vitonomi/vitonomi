---
import ComparisonGrid from '../components/ComparisonGrid.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import Hero from '../components/Hero.astro';
import Statement from '../components/Statement.astro';
import Steps from '../components/Steps.astro';
import Base from '../layouts/Base.astro';
import { SITE, type PageMeta } from '../config';

const meta: PageMeta = {
  title: 'vitonomi — unified private storage for all your sensitive data',
  description: SITE.defaultDescription,
  path: '/',
};

const mvpFeatures = [
  {
    title: 'Credential vault',
    body: 'A zero-knowledge password manager. Credentials are encrypted client-side and synced across your vaults. No cloud provider ever sees plaintext.',
  },
  {
    title: 'Email aliases',
    body: 'Receive-only aliases at servicexyz@username.vito.gg, or on any custom domain you own. Each alias has its own encryption key. The relay encrypts in RAM, stores nothing, logs nothing.',
  },
];

const steps = [
  {
    title: 'Encrypt',
    body: "All data is encrypted on your device before it leaves. Your vault, your hub, and vitonomi's servers never see plaintext.",
  },
  {
    title: 'Store',
    body: 'Your vaults — daemons on home servers, a VPS, or any always-on machine — hold the encrypted data. Replication across vaults keeps it safe.',
  },
  {
    title: 'Coordinate',
    body: 'A hub (hosted by vitonomi or self-hosted) manages vault discovery, cluster membership, and encrypted head pointers. It never touches your data.',
  },
];

const principles = [
  {
    title: 'Zero-knowledge',
    body: 'Data is encrypted on your device. Vaults store opaque blobs. The hub stores opaque pointers. Nobody in the chain can read your data.',
  },
  {
    title: 'Post-quantum',
    body: 'ML-DSA-65 signatures, ML-KEM-768 key encapsulation, XChaCha20-Poly1305 symmetric encryption. No harvest-now-decrypt-later risk.',
  },
  {
    title: 'Self-hostable',
    body: 'Every component — vault, hub, relay — runs on your own hardware. The hosted service is just one deployment of the same open-source binaries.',
  },
  {
    title: 'Open source',
    body: 'AGPL-3.0. Read every line of code. Fork it. Audit it. Run it yourself.',
  },
];
---

<Base meta={meta}>
  <Hero
    title="One vault for all your data."
    titleHtml={`One vault for all your <span class="accent">data</span>.`}
    subtitle="You shouldn't have to trust a corporation with your passwords, your photos, or your messages. vitonomi puts you back in control: you hold the keys, you hold the data, on hardware you choose."
    primaryCta={{ label: 'Get started', href: SITE.appUrl }}
    secondaryCta={{ label: 'How it works', href: '#how-it-works' }}
  />

  <section class="section-problem">
    <div class="container">
      <p class="eyebrow">Why it matters</p>
      <h2 data-reveal>Every service will be breached eventually.</h2>
      <p class="lede" data-reveal>
        Google, Apple, Meta — every centralised service stores your most private data on servers you
        don't control, encrypted with keys you don't hold. Breaches are not a question of if, but
        when. AI is accelerating that timeline.
      </p>
      <p class="lede" data-reveal>
        Credentials, email aliases, photos, and more — encrypted on your device, stored on your
        terms. Self-hostable. Post-quantum secure. Open source.
      </p>
      <div class="comparison-wrap" data-reveal>
        <ComparisonGrid
          before={{
            title: 'Corporate services',
            items: [
              'Your data used for AI training',
              'Their keys, their rules',
              'Breached when, not if',
              'Scattered across providers',
              'Locked in, priced up yearly',
              'Closed source, trust required',
            ],
          }}
          after={{
            title: 'vitonomi',
            items: [
              'Your data on your hardware',
              'Your keys, always',
              'Zero-knowledge by design',
              'One vault for everything',
              'Self-hostable, no lock-in',
              'Open source, auditable',
            ],
          }}
        />
      </div>
    </div>
  </section>

  <section class="alt">
    <div class="container">
      <p class="eyebrow">Day one</p>
      <h2 data-reveal>Credentials and email aliases. Ready at launch.</h2>
      <div class="mvp-features">
        <FeatureGrid features={mvpFeatures} columns={2} />
      </div>
      <p class="coming-note" data-reveal>
        Photos, videos, documents, and more data types ship in v1.1.
      </p>
    </div>
  </section>

  <section id="how-it-works">
    <div class="container">
      <p class="eyebrow">How it works</p>
      <h2 data-reveal>Vaults, hubs, and clusters.</h2>
      <div class="how">
        <Steps steps={steps} />
      </div>
    </div>
  </section>

  <section class="alt">
    <div class="container">
      <p class="eyebrow">Principles</p>
      <h2 data-reveal>Built around four promises.</h2>
      <div class="principles">
        <FeatureGrid features={principles} columns={4} />
      </div>
    </div>
  </section>

  <section class="section-trust">
    <div class="container">
      <Statement
        text="Our servers never store your data. Not the bytes. Not the metadata. Not the keys."
        highlight="never"
        caption="Dual-key Argon2id, client-side encryption, and post-quantum cryptography end to end. Every vault and hub deployment uses the same zero-knowledge design."
      />
      <div class="actions" data-reveal>
        <a class="cta cta--ghost" href="/privacy">Read the security details</a>
      </div>
    </div>
  </section>

  <section class="alt">
    <div class="container">
      <p class="eyebrow">Families and teams</p>
      <h2 data-reveal>One cluster. Everyone keeps their own keys.</h2>
      <p class="lede" data-reveal>
        Create a cluster for your family or organisation. The admin invites members and sets
        per-user quotas, but cannot read anyone's data. Each member holds their own encryption keys
        — generated on their own device, never shared.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <p class="eyebrow">Open source, self-host first</p>
      <div class="open-source">
        <h2 data-reveal>Run every component yourself.</h2>
        <p class="lede" data-reveal>
          vitonomi is not a walled garden. The vault daemon, the hub server, and the SMTP relay are
          all open-source AGPL-3.0 binaries. Deploy them on your hardware and keep zero dependency
          on vitonomi infrastructure.
        </p>
        <div class="actions" data-reveal>
          <a class="cta" href="/self-hosting">Learn about self-hosting</a>
          <a class="cta cta--ghost" href={SITE.repoUrl} rel="noopener noreferrer">
            Browse the source
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="tight section-cta">
    <div class="container">
      <p class="eyebrow">Get started</p>
      <h2 data-reveal>Your data. One vault. Fully encrypted.</h2>
      <div class="actions" data-reveal>
        <a class="cta" href={SITE.appUrl}>Open vitonomi</a>
        <a class="cta cta--ghost" href="/self-hosting">Or self-host</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .comparison-wrap {
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
  }
  .mvp-features {
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
  }
  .coming-note {
    margin-top: 1.5rem;
    font-size: 0.9rem;
    color: var(--text-soft);
  }
  .how {
    margin-top: clamp(2rem, 3vw, 3rem);
  }
  .principles {
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
  }
  .open-source h2 {
    max-width: 25ch;
  }
  .section-problem {
    background:
      radial-gradient(ellipse 50% 50% at 0% 100%, var(--glow-amber), transparent), var(--bg);
  }
  .section-trust {
    background:
      radial-gradient(ellipse 50% 60% at 50% 50%, var(--glow-warm), transparent), var(--bg);
  }
  .section-cta {
    background:
      radial-gradient(ellipse 70% 50% at 50% 0%, var(--glow-orange), transparent), var(--bg);
  }
</style>
