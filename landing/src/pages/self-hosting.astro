---
import FeatureGrid from '../components/FeatureGrid.astro';
import Hero from '../components/Hero.astro';
import Steps from '../components/Steps.astro';
import Base from '../layouts/Base.astro';
import { SITE, type PageMeta } from '../config';

const meta: PageMeta = {
  title: 'Self-hosting vitonomi — run the vault, hub, and relay yourself',
  description:
    'Every component in vitonomi — the vault daemon, the hub server, and the SMTP relay — is an open-source AGPL-3.0 binary you can run on your own hardware.',
  path: '/self-hosting',
};

const whyPoints = [
  {
    title: 'No dependence on vitonomi',
    body: 'If vitonomi disappears, self-hosters lose nothing. The vault, hub, and relay binaries, the data format, and your keys all stay in your hands.',
  },
  {
    title: 'Your hardware, your rules',
    body: 'Run vaults on a Raspberry Pi, a NAS, or a VPS. Run the hub on the same box or a separate one. You choose the topology.',
  },
  {
    title: 'Bring your own relay',
    body: 'Host vitonomi-mx on your own domain for email aliases with zero vitonomi exposure. Or skip the relay entirely and use only credential storage.',
  },
];

const steps = [
  {
    title: 'Install the vault',
    body: 'Clone the repo, build with npm install, and start the vault daemon. It listens on libp2p and dials the hub for coordination.',
  },
  {
    title: 'Run a hub (or use ours)',
    body: 'Start the hub server alongside your vault for full independence, or point your vault at hub.vitonomi.com for a zero-config start. Same binary either way.',
  },
  {
    title: 'Create your cluster',
    body: 'Initialise a cluster, invite family members, and set per-user quotas. Each member generates their own encryption keys on their own device.',
  },
];
---

<Base meta={meta} breadcrumbName="Self-hosting">
  <Hero
    eyebrow="Self-hosting"
    title="Run it yourself. Keep every key."
    subtitle="Every component in vitonomi — the vault daemon, the hub server, and the SMTP relay — is an open-source AGPL-3.0 binary you can run on your own hardware."
    primaryCta={{ label: 'Read the docs on GitHub', href: SITE.docsBaseUrl }}
    secondaryCta={{ label: 'Browse the source', href: SITE.repoUrl }}
  />

  <section>
    <div class="container">
      <p class="eyebrow">Why self-host</p>
      <h2 data-reveal>Keep the keys. Keep the infrastructure. Keep the code.</h2>
      <div class="why">
        <FeatureGrid features={whyPoints} columns={3} />
      </div>
    </div>
  </section>

  <section class="alt">
    <div class="container">
      <p class="eyebrow">Three steps</p>
      <h2 data-reveal>From clone to first vault in minutes.</h2>
      <div class="steps-wrap">
        <Steps steps={steps} />
      </div>
    </div>
  </section>

  <section>
    <div class="container container--prose prose">
      <p class="eyebrow">What you get</p>
      <h2 data-reveal>Exactly what hosted users get. Built from the same code.</h2>
      <ul data-reveal>
        <li>
          The same web UI, CLI, and vault daemon as hosted users — same repository, same release.
        </li>
        <li>No subscription, no margin, no vendor lock-in.</li>
        <li>A one-page audit trail: the data format is documented and versioned.</li>
        <li>A working recovery path from a BIP-39-style seed phrase.</li>
        <li>Cluster support — invite family members, each with their own keys.</li>
      </ul>
      <p class="lede" data-reveal>
        Prefer a hosted hub with managed infrastructure? Open
        <a class="link-inline" href={SITE.appUrl}>vitonomi.app</a> and get started in a minute.
      </p>
    </div>
  </section>
</Base>

<style>
  .why,
  .steps-wrap {
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
  }
</style>
