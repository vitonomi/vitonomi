---
import FeatureGrid from '../components/FeatureGrid.astro';
import Hero from '../components/Hero.astro';
import Statement from '../components/Statement.astro';
import Base from '../layouts/Base.astro';
import { SITE, type PageMeta } from '../config';

const meta: PageMeta = {
  title: 'Privacy & security — how vitonomi protects your data',
  description:
    'Dual-key Argon2id, client-side encryption, a log-free SMTP relay, and post-quantum cryptography (ML-DSA-65 + ML-KEM-768) end to end.',
  path: '/privacy',
};

const layers = [
  {
    title: 'Dual-key derivation',
    body: 'Your password runs through Argon2id with two salts. One derives the auth key (sent to the server). One derives the encryption key (never leaves your device).',
  },
  {
    title: 'Client-side encryption',
    body: 'All data — credentials, emails, eventually photos — is encrypted on your device before it reaches a vault. Only ciphertext ever leaves your browser or CLI.',
  },
  {
    title: 'Confidential relay',
    body: 'The vitonomi-mx SMTP relay processes inbound email in RAM only. Each alias has its own ML-KEM-768 public key; the relay encrypts on receive and holds zero plaintext on disk or in logs.',
  },
  {
    title: 'Post-quantum',
    body: 'Every signature is ML-DSA-65. Every key encapsulation is ML-KEM-768. Harvest-now-decrypt-later is out of scope.',
  },
];

const threats = [
  {
    title: 'Malicious vitonomi hub',
    body: 'Worst case: we see encrypted head pointers, cluster membership graphs, and alias-to-pubkey mappings. We see zero plaintext records, zero encryption keys.',
  },
  {
    title: 'Malicious vault operator',
    body: 'Vaults store opaque encrypted records they cannot decrypt. Content-addressing ensures they cannot substitute fake data without breaking retrieval.',
  },
  {
    title: 'Malicious relay',
    body: 'The relay binary is open source and log-free. It encrypts to per-alias public keys in RAM. A compromised relay instance can read inbound mail in transit but cannot decrypt already-stored messages.',
  },
  {
    title: 'Lost password',
    body: 'Recover from a BIP-39 seed phrase. Re-derive your keys, reconnect to your vaults, walk your signed snapshot chain. Full library reconstruction without any vendor.',
  },
];
---

<Base meta={meta} breadcrumbName="Privacy & security">
  <Hero
    eyebrow="Privacy & security"
    title="Four layers. Zero plaintext on our side."
    subtitle="vitonomi's security promise is specific and testable: our infrastructure never sees plaintext data, metadata, or encryption keys."
    primaryCta={{ label: 'Read the source', href: SITE.repoUrl }}
  />

  <section>
    <div class="container">
      <p class="eyebrow">How your data is protected</p>
      <h2 data-reveal>Four layers of defence, end to end.</h2>
      <div class="layers">
        <FeatureGrid features={layers} columns={2} />
      </div>
    </div>
  </section>

  <section class="alt">
    <div class="container">
      <p class="eyebrow">Threat model at a glance</p>
      <h2 data-reveal>What each attacker can and cannot do.</h2>
      <p class="lede" data-reveal>
        Our full threat model is being published alongside the v1.0 release. Here is the short
        version.
      </p>
      <div class="threats">
        <FeatureGrid features={threats} columns={2} />
      </div>
    </div>
  </section>

  <section>
    <div class="container container--prose prose">
      <p class="eyebrow">Cryptographic choices</p>
      <h2 data-reveal>The primitives we rely on, in one place.</h2>
      <ul data-reveal>
        <li>
          <strong>Password KDF:</strong> Argon2id, memory &ge; 256 MiB, run in a Web Worker — Grover-resistant
          at current parameters.
        </li>
        <li>
          <strong>Symmetric AEAD:</strong> XChaCha20-Poly1305 with 256-bit keys. Grover halves effective
          security; 128-bit is still comfortable.
        </li>
        <li>
          <strong>Signatures:</strong> ML-DSA-65 (post-quantum, NIST FIPS 204).
        </li>
        <li>
          <strong>Key encapsulation:</strong> ML-KEM-768 (post-quantum, NIST FIPS 203).
        </li>
      </ul>
      <p class="note" data-reveal>Autonomi self-encryption is planned for v1.1 backup targets.</p>
    </div>
  </section>

  <section class="alt">
    <div class="container">
      <Statement
        text="Trust, but verify."
        caption="The full cryptographic surface, byte layouts, and threat model live in the open repo under AGPL-3.0."
      />
      <div class="actions" data-reveal>
        <a class="cta" href={`${SITE.repoUrl}/tree/main/core/src/crypto`} rel="noopener noreferrer">
          Read core/src/crypto on GitHub
        </a>
        <a
          class="cta cta--ghost"
          href={`${SITE.docsBaseUrl}/data-format.md`}
          rel="noopener noreferrer"
        >
          Read the data format
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .layers,
  .threats {
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
  }
  .note {
    margin-top: 1.5rem;
    font-size: 0.9rem;
    color: var(--text-soft);
  }
</style>
